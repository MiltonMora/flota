---
import AppLayout from '@/layouts/AppLayout.astro';
import TransactionModal from '@/components/TransactionModal.astro';
import TransactionEditModal from '@/components/TransactionEditModal.astro';
import { db } from '@/db';
import { transactions, vehicles, userVehicles } from '@/db/schema';
import { eq, desc, sql, and, gte, lte } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/');

// Rango de fechas desde query params (o mes actual por defecto)
const url      = Astro.url;
const now      = new Date();
const fromParam = url.searchParams.get('from');
const toParam   = url.searchParams.get('to');

const from = fromParam ? new Date(fromParam) : new Date(now.getFullYear(), now.getMonth(), 1);
const to   = toParam   ? new Date(toParam)   : new Date(now.getFullYear(), now.getMonth() + 1, 0, 23, 59, 59);

const monthLabel = from.toLocaleDateString('es-ES', { month: 'long', year: 'numeric' });

// Vehículos del usuario
const userVehicleList = await db
  .select({ id: vehicles.id, plate: vehicles.plate, brand: vehicles.brand, model: vehicles.model })
  .from(userVehicles)
  .innerJoin(vehicles, eq(userVehicles.vehicleId, vehicles.id))
  .where(eq(userVehicles.userId, user.id));

const vehicleIds = userVehicleList.map((v) => v.id);

let total = 0;
let list: any[] = [];

if (vehicleIds.length > 0) {
  const inList = sql.join(vehicleIds.map((id) => sql`${id}`), sql`, `);

  const [totals] = await db
    .select({ total: sql<number>`COALESCE(SUM(${transactions.amount}), 0)` })
    .from(transactions)
    .where(and(
      sql`${transactions.vehicleId} IN (${inList})`,
      eq(transactions.type, 'income'),
      gte(transactions.date, from),
      lte(transactions.date, to),
    ));

  total = totals?.total ?? 0;

  list = await db
    .select({
      id:          transactions.id,
      amount:      transactions.amount,
      description: transactions.description,
      date:        transactions.date,
      plate:       vehicles.plate,
      vehicleId:   transactions.vehicleId
    })
    .from(transactions)
    .innerJoin(vehicles, eq(transactions.vehicleId, vehicles.id))
    .where(and(
      sql`${transactions.vehicleId} IN (${inList})`,
      eq(transactions.type, 'income'),
      gte(transactions.date, from),
      lte(transactions.date, to),
    ))
    .orderBy(desc(transactions.date));
}

const currency = (v: number) =>
  new Intl.NumberFormat('es-ES', { style: 'currency', currency: 'COP' }).format(v);

const formatDate = (d: Date | number) =>
  new Intl.DateTimeFormat('es-ES', { day: '2-digit', month: 'short' }).format(new Date(d));

const fromISO = from.toISOString().split('T')[0];
const toISO   = to.toISOString().split('T')[0];
---

<AppLayout title="Ingresos · Flota Vial">
  <div class="page">

    <header class="page-header">
      <p class="kicker">movimientos</p>
      <h1 class="title">Ingresos</h1>
    </header>

    <!-- Resumen del período -->
    <div class="summary-row">
      <div class="summary-card">
        <p class="summary-label">Total período</p>
        <p class="summary-val income">{currency(total)}</p>
      </div>
      <div class="summary-card">
        <p class="summary-label">Registros</p>
        <p class="summary-val navy">{list.length}</p>
      </div>
    </div>

    <!-- Filtro de fechas -->
    <form method="GET" class="filter-form" id="filter-form">
      <div class="filter-bar">
        <button type="button" id="btn-this-month" class={`chip ${!fromParam ? 'chip-active-income' : ''}`}>
          Este mes
        </button>
        <button type="button" id="btn-range" class={`chip ${fromParam ? 'chip-active-income' : ''}`}>
          Por rango
        </button>
      </div>

      <div id="range-inputs" class={`range-inputs ${fromParam ? 'open' : ''}`}>
        <div class="range-field">
          <label>Desde</label>
          <input type="date" name="from" value={fromISO} class="date-input" />
        </div>
        <div class="range-field">
          <label>Hasta</label>
          <input type="date" name="to" value={toISO} class="date-input" />
        </div>
        <button type="submit" class="btn-filter-income">Buscar</button>
      </div>
    </form>

    <p class="period-label">{monthLabel}</p>

    <!-- Lista -->
    <div class="list">
      {list.length === 0
        ? <div class="empty">Sin ingresos en este período.</div>
        : list.map((tx) => (
            <div class="tx-card">
              <div class="tx-left">
                <p class="tx-desc">{tx.description}</p>
                <div class="tx-meta">
                  <span class="badge-plate">{tx.plate}</span>
                  <span>{formatDate(tx.date)}</span>
                </div>
              </div>
              <div class="tx-right">
                <p class="tx-amount income">+{currency(tx.amount)}</p>
                <button
                  class="edit-btn"
                  data-id={tx.id}
                  data-type="income"
                  data-amount={tx.amount}
                  data-description={tx.description}
                  data-vehicle-id={tx.vehicleId}
                  data-date={tx.date}
                  aria-label="Editar"
                >
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  </svg>
                </button>
              </div>
            </div>
          ))
      }
    </div>

  </div>

  <!-- FAB -->
  <button id="fab-income" class="fab fab-income" aria-label="Nuevo ingreso">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
      <path d="M12 5v14M5 12h14" stroke="white" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </button>

  <TransactionModal vehicles={userVehicleList} />
  <TransactionEditModal vehicles={userVehicleList} />
</AppLayout>

<style>
  .page {
    padding: 1.25rem 1.25rem calc(6rem + env(safe-area-inset-bottom));
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-height: 100dvh;
    background: var(--color-asphalt);
  }

  .kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-income);
    letter-spacing: 0.05em;
    margin-bottom: 2px;
    opacity: 0.7;
  }

  .title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-income);
    line-height: 1;
  }

  .summary-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }

  .summary-card {
    background: white;
    border-radius: 10px;
    padding: 12px 14px;
    border: 0.5px solid #e5e7eb;
  }

  .summary-label {
    font-family: var(--font-mono);
    font-size: 9px;
    color: #B4B2A9;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 5px;
  }

  .summary-val { font-family: var(--font-mono); font-size: 18px; font-weight: 500; }
  .summary-val.income { color: var(--color-income); }
  .summary-val.navy   { color: var(--color-navy);   }

  /* Filtro */
  .filter-form { display: flex; flex-direction: column; gap: 8px; }

  .filter-bar { display: flex; gap: 8px; }

  .chip {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 6px 14px;
    border-radius: 99px;
    border: 0.5px solid #e5e7eb;
    background: white;
    color: #888780;
    cursor: pointer;
    transition: all 0.15s;
  }

  .chip-active-income {
    background: var(--color-income);
    color: white;
    border-color: var(--color-income);
  }

  .range-inputs {
    display: none;
    flex-direction: column;
    gap: 8px;
    background: white;
    border-radius: 10px;
    padding: 12px 14px;
    border: 0.5px solid #e5e7eb;
  }
  .range-inputs.open { display: flex; }

  .range-field { display: flex; flex-direction: column; gap: 4px; }

  .range-field label {
    font-family: var(--font-mono);
    font-size: 9px;
    color: #B4B2A9;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .date-input {
    border: none;
    outline: none;
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--color-carbon);
    background: transparent;
    width: 100%;
  }

  .btn-filter-income {
    padding: 10px;
    border-radius: 8px;
    background: var(--color-income);
    color: white;
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
    border: none;
    cursor: pointer;
    margin-top: 4px;
  }

  .period-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: #888780;
    letter-spacing: 0.05em;
    text-transform: capitalize;
  }

  /* Lista */
  .list { display: flex; flex-direction: column; gap: 8px; }

  .tx-card {
    background: white;
    border-radius: 10px;
    padding: 12px 14px;
    border: 0.5px solid #e5e7eb;
    display: flex;
    justify-content: space-between;
    align-items: center;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .tx-card:hover { opacity: 0.8; }

  .tx-right {
    display: flex; align-items: center; gap: 10px; flex-shrink: 0;
  }

  /* income */
  .edit-btn {
    width: 30px; height: 30px; border-radius: 8px;
    background: var(--color-income-light); color: var(--color-income);
    border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: opacity 0.15s;
  }

  .tx-left { flex: 1; min-width: 0; }

  .tx-desc {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
    color: var(--color-carbon);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .tx-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 4px;
    font-family: var(--font-mono);
    font-size: 10px;
    color: #B4B2A9;
  }

  .tx-amount {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    white-space: nowrap;
    margin-left: 12px;
  }
  .tx-amount.income { color: var(--color-income); }

  .empty {
    background: white;
    border: 0.5px dashed #d1d5db;
    border-radius: 10px;
    padding: 1.5rem;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 11px;
    color: #B4B2A9;
    letter-spacing: 0.04em;
  }

  /* FAB */
  .fab {
    position: fixed;
    bottom: calc(5rem + env(safe-area-inset-bottom));
    right: 1.25rem;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 14px rgba(0,0,0,0.18);
    transition: opacity 0.15s, transform 0.15s;
    z-index: 50;
  }
  .fab:hover  { opacity: 0.9; transform: scale(1.05); }
  .fab:active { transform: scale(0.95); }
  .fab-income { background: var(--color-income); }
</style>

<script>
  const btnMonth = document.getElementById('btn-this-month')!;
  const btnRange = document.getElementById('btn-range')!;
  const rangeInputs = document.getElementById('range-inputs')!;

  btnMonth.addEventListener('click', () => {
    window.location.href = '/transactions/income';
  });

  btnRange.addEventListener('click', () => {
    rangeInputs.classList.toggle('open');
    btnRange.classList.toggle('chip-active-income');
    btnMonth.classList.remove('chip-active-income');
  });

  document.getElementById('fab-income')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('open-tx-modal', { detail: { type: 'income' } }));
  });

  document.querySelectorAll('.edit-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const d = (btn as HTMLElement).dataset;
      document.dispatchEvent(new CustomEvent('open-tx-edit', {
        detail: {
          id:          d.id,
          type:        d.type,
          amount:      d.amount,
          description: d.description,
          vehicleId:   d.vehicleId,
          date:        d.date,
        }
      }));
    });
  });

</script>