---
import AppLayout from '@/layouts/AppLayout.astro';
import { db } from '@/db';
import { vehicles, userVehicles } from '@/db/schema';
import { nanoid } from 'nanoid';
import { z } from 'zod';

const user = Astro.locals.user;

if (!user) {
  return Astro.redirect('/');
}

const vehicleSchema = z.object({
  plate: z.string().min(5).max(12),
  brand: z.string().min(2).max(50),
  model: z.string().min(1).max(50),
  year: z.coerce.number().min(1900).max(new Date().getFullYear() + 1),
  description: z.string().max(300).optional(),
});

let error = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();

  const parsed = vehicleSchema.safeParse({
    plate: formData.get('plate'),
    brand: formData.get('brand'),
    model: formData.get('model'),
    year: formData.get('year'),
    description: formData.get('description'),
  });

  if (!parsed.success) {
    error = 'Revisa los datos ingresados.';
  } else {
    try {
      const vehicleId = nanoid();

      await db.insert(vehicles).values({
        id: vehicleId,
        plate: parsed.data.plate.toUpperCase(),
        brand: parsed.data.brand,
        model: parsed.data.model,
        year: parsed.data.year,
        description: parsed.data.description,
        createdBy: user.id,
        updatedBy: user.id,
      });

      await db.insert(userVehicles).values({
        userId: user.id,
        vehicleId,
      });

      return Astro.redirect('/dashboard');
    } catch (e) {
      error = 'No se pudo registrar el vehículo. La matrícula podría existir.';
    }
  }
}
---

<AppLayout title="Nuevo Vehículo | Flota Vial">
  <section class="vehicle-page">
    <header class="page-header">
      <div>
        <p class="page-kicker">Gestión vehicular</p>
        <h1>Registrar vehículo</h1>
      </div>
      <a href="/dashboard" class="back-link">Volver</a>
    </header>

    <section class="hero-card">
      <div>
        <p class="hero-title">Añade una nueva unidad</p>
        <p class="hero-subtitle">Registra vehículos para controlar ingresos, gastos y trazabilidad.</p>
      </div>
    </section>

    {error && (
      <div class="error-msg">
        {error}
      </div>
    )}

    <form method="POST" class="vehicle-form card">
      <div class="form-group plate-group">
        <label for="plate">Matrícula</label>
        <input
          id="plate"
          name="plate"
          type="text"
          required
          maxlength="12"
          class="input plate-input"
          placeholder="1234ABC"
          style="text-transform: uppercase;"
        />
      </div>

      <div class="form-grid">
        <div class="form-group">
          <label for="brand">Marca</label>
          <input
            id="brand"
            name="brand"
            type="text"
            required
            class="input"
            placeholder="Toyota"
          />
        </div>

        <div class="form-group">
          <label for="model">Modelo</label>
          <input
            id="model"
            name="model"
            type="text"
            required
            class="input"
            placeholder="Corolla"
          />
        </div>
      </div>

      <div class="form-group">
        <label for="year">Año</label>
        <input
          id="year"
          name="year"
          type="number"
          required
          class="input"
          min="1900"
          max={new Date().getFullYear() + 1}
          placeholder="2024"
        />
      </div>

      <div class="form-group">
        <label for="description">Descripción / Notas</label>
        <textarea
          id="description"
          name="description"
          class="input textarea"
          rows="4"
          placeholder="Color, uso, observaciones..."
        ></textarea>
      </div>

      <div class="form-actions">
        <a href="/dashboard" class="btn-secondary action-btn">Cancelar</a>
        <button type="submit" class="btn-primary action-btn">Guardar vehículo</button>
      </div>
    </form>
  </section>
</AppLayout>

<style>
  .vehicle-page {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    min-height: 100%;
    background:
      radial-gradient(circle at top right, rgba(245,166,35,0.16), transparent 28%),
      linear-gradient(to bottom, var(--color-navy-light) 0%, #f4f7fb 38%, var(--color-asphalt) 100%);
  }

  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.5rem 0.25rem;
  }

  .page-kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-navy-mid);
    margin-bottom: 4px;
  }

  h1 {
    font-size: 2rem;
    color: var(--color-navy);
    line-height: 1;
  }

  .back-link {
    font-size: 13px;
    color: var(--color-navy);
    text-decoration: none;
    font-weight: 600;
    background: white;
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    border: 1px solid #dce6f3;
    box-shadow: 0 4px 10px rgba(28, 63, 110, 0.06);
  }

  .hero-card {
    display: flex;
    gap: 1rem;
    align-items: center;
    background:
      linear-gradient(135deg, var(--color-navy) 0%, var(--color-navy-mid) 68%, var(--color-amber-accent) 145%);
    padding: 1.15rem;
    border-radius: 20px;
    box-shadow: 0 14px 28px rgba(28, 63, 110, 0.22);
    position: relative;
    overflow: hidden;
  }

  .hero-title {
    font-weight: 600;
    font-size: 12px;
  }

  .hero-subtitle {
    font-size: 12px;
    opacity: 0.85;
    line-height: 1.5;
    margin-top: 4px;
  }

  .vehicle-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-radius: 20px;
    padding: 1.25rem;
    background: rgba(255,255,255,0.92);
    border: 1px solid rgba(230, 241, 251, 0.95);
    box-shadow:
      0 10px 24px rgba(28, 63, 110, 0.08),
      inset 0 1px 0 rgba(255,255,255,0.9);
    backdrop-filter: blur(10px);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    position: relative;
    padding: .05rem 1.5rem;
  }

  label {
    font-size: 11px;
    font-weight: 700;
    color: var(--color-navy-mid);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding-left: 2px;
  }

  .plate-input {
    font-family: var(--font-mono);
    letter-spacing: 0.16em;
    font-weight: 600;
    text-align: center;
    font-size: 17px;
    border: 1px solid;
    border-radius: 0.5em;
  }

  .textarea {
    resize: vertical;
    min-height: 110px;
    background: linear-gradient(to bottom, #ffffff, #f9fbfd);
    padding-top: 0.85rem;
  }

  .form-actions {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid #edf2f7;
  }

  .action-btn {
    text-align: center;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 44px;
    border-radius: 10px;
  }

  .error-msg {
    background: linear-gradient(135deg, var(--color-expense-light), #fff5f5);
    color: var(--color-expense);
    padding: 0.95rem 1rem;
    border-radius: 12px;
    font-size: 13px;
    font-weight: 500;
    border: 1px solid rgba(163,45,45,0.12);
    box-shadow: 0 4px 10px rgba(163,45,45,0.06);
  }
  .input {
    min-height: 5px;
    border: 1.5px solid ;
    border-radius: .5em;
    padding: 0.95rem 1rem;
    font-size: 15px;
  }

  .input:hover {
    border-color: #bfd3eb;
  }

  .input:focus {
    border-color: var(--color-navy-mid);
    background: white;
    box-shadow:
      0 0 0 4px rgba(42,95,165,0.12),
      0 6px 14px rgba(28,63,110,0.06);
    transform: translateY(-1px);
  }
</style>