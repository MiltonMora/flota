---
import AppLayout from '@/layouts/AppLayout.astro';
import VehicleModal from '@/components/VehicleModal.astro';
import VehicleEditModal from '@/components/VehicleEditModal.astro';
import { db } from '@/db';
import { vehicles, userVehicles } from '@/db/schema';
import { eq } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/');

const list = await db
  .select({
    id:    vehicles.id,
    plate: vehicles.plate,
    brand: vehicles.brand,
    model: vehicles.model,
    year:  vehicles.year,
    description: vehicles.description,
  })
  .from(userVehicles)
  .innerJoin(vehicles, eq(userVehicles.vehicleId, vehicles.id))
  .where(eq(userVehicles.userId, user.id));
---

<AppLayout title="Vehículos · Flota Vial">
  <div class="page">

    <header class="page-header">
      <p class="kicker">flota</p>
      <h1 class="title">Vehículos</h1>
    </header>

    <div class="search-bar">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
        <circle cx="11" cy="11" r="7" stroke="#B4B2A9" stroke-width="1.8"/>
        <path d="M16.5 16.5L21 21" stroke="#B4B2A9" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
      <input id="search-input" type="text" placeholder="Buscar por matrícula o marca..." autocomplete="off" />
    </div>

    <div class="list" id="vehicle-list">
      {list.length === 0
        ? <div class="empty">No tenés vehículos registrados.</div>
        : list.map((v) => (
            <div class="card vehicle-card" data-search={`${v.plate} ${v.brand} ${v.model}`.toLowerCase()}>
              <div>
                <span class="badge-plate">{v.plate}</span>
                <p class="vehicle-name">{v.brand} {v.model}</p>
                <p class="vehicle-year">{v.year}</p>
              </div>
              <button
                class="edit-btn"
                data-id={v.id}
                data-plate={v.plate}
                data-brand={v.brand}
                data-model={v.model}
                data-year={v.year}
                data-description={v.description ?? ''}
                aria-label="Editar vehículo"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                </svg>
              </button>
            </div>
          ))
      }
    </div>

  </div>

  <!-- FAB -->
  <button id="fab-vehicle" class="fab fab-navy" aria-label="Nuevo vehículo">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
      <path d="M12 5v14M5 12h14" stroke="white" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </button>

  <VehicleModal />
  <VehicleEditModal />
</AppLayout>

<style>
  .page {
    padding: 1.25rem 1.25rem calc(6rem + env(safe-area-inset-bottom));
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-height: 100dvh;
    background: var(--color-asphalt);
  }

  .kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-navy-mid);
    letter-spacing: 0.05em;
    margin-bottom: 2px;
  }

  .title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-navy);
    line-height: 1;
  }

  .search-bar {
    background: white;
    border-radius: 10px;
    padding: 10px 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    border: 0.5px solid #e5e7eb;
  }

  .search-bar input {
    border: none;
    outline: none;
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--color-carbon);
    background: transparent;
    width: 100%;
  }
  .search-bar input::placeholder { color: #B4B2A9; }

  .list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .vehicle-card {display: flex; justify-content: space-between; align-items: center; }
  .vehicle-card:hover { opacity: 0.8; }
  .vehicle-card.hidden { display: none; }

  .vehicle-name {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-carbon);
    margin-top: 5px;
  }

  .vehicle-year {
    font-family: var(--font-mono);
    font-size: 11px;
    color: #888780;
    margin-top: 2px;
  }

  .empty {
    background: white;
    border: 0.5px dashed #d1d5db;
    border-radius: 10px;
    padding: 1.5rem;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 11px;
    color: #B4B2A9;
    letter-spacing: 0.04em;
  }

  .fab {
    position: fixed;
    bottom: calc(5rem + env(safe-area-inset-bottom));
    right: 1.25rem;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 14px rgba(0,0,0,0.18);
    transition: opacity 0.15s, transform 0.15s;
    z-index: 50;
  }
  .fab:hover  { opacity: 0.9; transform: scale(1.05); }
  .fab:active { transform: scale(0.95); }
  .fab-navy { background: var(--color-navy); }

  .edit-btn {
  width: 32px; height: 32px;
  border-radius: 8px;
  background: var(--color-navy-light);
  color: var(--color-navy);
  border: none; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  transition: background 0.15s;
}
.edit-btn:hover { background: #cce0f5; }
</style>

<script>
  // Búsqueda en tiempo real
  document.getElementById('search-input')?.addEventListener('input', (e) => {
    const q = (e.target as HTMLInputElement).value.toLowerCase().trim();
    document.querySelectorAll<HTMLElement>('.vehicle-card').forEach((card) => {
      const match = card.dataset.search?.includes(q) ?? true;
      card.classList.toggle('hidden', !match);
    });
  });

  document.querySelectorAll('.edit-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const d = (btn as HTMLElement).dataset;
      document.dispatchEvent(new CustomEvent('open-vehicle-edit', {
        detail: {
          id:          d.id,
          plate:       d.plate,
          brand:       d.brand,
          model:       d.model,
          year:        d.year,
          description: d.description,
        }
      }));
    });
  });

  // FAB abre modal
  document.getElementById('fab-vehicle')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('open-vehicle-modal'));
  });
</script>