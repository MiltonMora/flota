---
import VehicleModal from '@/components/VehicleModal.astro';
import TransactionModal from '@/components/TransactionModal.astro';
import AppLayout from '@/layouts/AppLayout.astro';
import { db } from '@/db';
import { vehicles, transactions, userVehicles } from '@/db/schema';
import { eq, desc, sql, and, gte, lte } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/');

// ── Rango de fechas ──────────────────────────────────────────────────────────
const url       = Astro.url;
const now       = new Date();
const fromParam = url.searchParams.get('from');
const toParam   = url.searchParams.get('to');

const from = fromParam
  ? new Date(fromParam)
  : new Date(now.getFullYear(), now.getMonth(), 1);

const to = toParam
  ? new Date(toParam)
  : new Date(now.getFullYear(), now.getMonth() + 1, 0, 23, 59, 59);

const fromISO = from.toISOString().split('T')[0];
const toISO   = to.toISOString().split('T')[0];

const periodLabel = (() => {
  const sameMonth = from.getMonth()    === to.getMonth()
                 && from.getFullYear() === to.getFullYear();
  if (sameMonth) {
    return from.toLocaleDateString('es-ES', { month: 'short', year: 'numeric' });
  }
  const f = from.toLocaleDateString('es-ES', { day: '2-digit', month: 'short' });
  const t = to.toLocaleDateString('es-ES',   { day: '2-digit', month: 'short', year: 'numeric' });
  return `${f} — ${t}`;
})();

// ── Vehículos ────────────────────────────────────────────────────────────────
const userVehicleList = await db
  .select({
    id:    vehicles.id,
    plate: vehicles.plate,
    brand: vehicles.brand,
    model: vehicles.model,
    year:  vehicles.year,
  })
  .from(userVehicles)
  .innerJoin(vehicles, eq(userVehicles.vehicleId, vehicles.id))
  .where(eq(userVehicles.userId, user.id));

const vehicleIds = userVehicleList.map((v) => v.id);

// ── Totales del período ──────────────────────────────────────────────────────
let incomeTotal  = 0;
let expenseTotal = 0;
let recentTransactions: any[] = [];

if (vehicleIds.length > 0) {
  const inList = sql.join(vehicleIds.map((id) => sql`${id}`), sql`, `);

  const whereClause = and(
    sql`${transactions.vehicleId} IN (${inList})`,
    gte(transactions.date, from),
    lte(transactions.date, to),
  );

  const [totals] = await db
    .select({
      income:  sql<number>`COALESCE(SUM(CASE WHEN ${transactions.type} = 'income'  THEN ${transactions.amount} ELSE 0 END), 0)`,
      expense: sql<number>`COALESCE(SUM(CASE WHEN ${transactions.type} = 'expense' THEN ${transactions.amount} ELSE 0 END), 0)`,
    })
    .from(transactions)
    .where(whereClause);

  incomeTotal  = totals?.income  ?? 0;
  expenseTotal = totals?.expense ?? 0;

  recentTransactions = await db
    .select({
      id:          transactions.id,
      amount:      transactions.amount,
      type:        transactions.type,
      description: transactions.description,
      date:        transactions.date,
      plate:       vehicles.plate,
    })
    .from(transactions)
    .innerJoin(vehicles, eq(transactions.vehicleId, vehicles.id))
    .where(whereClause)
    .orderBy(desc(transactions.date))
    .limit(8);
}

const balance = incomeTotal - expenseTotal;

// ── Helpers ──────────────────────────────────────────────────────────────────
const currency = (v: number) =>
  new Intl.NumberFormat('es-ES', { style: 'currency', currency: 'COP', maximumFractionDigits: 2 }).format(v);

const formatDate = (d: Date | number) =>
  new Intl.DateTimeFormat('es-ES', { day: '2-digit', month: 'short' }).format(new Date(d));

const initials = (name?: string | null) =>
  name?.split(' ').slice(0, 2).map((n) => n[0]).join('').toUpperCase() ?? '?';

// Mes anterior y año actual para los chips
const prevMonthFrom = new Date(now.getFullYear(), now.getMonth() - 1, 1).toISOString().split('T')[0];
const prevMonthTo   = new Date(now.getFullYear(), now.getMonth(), 0, 23, 59, 59).toISOString().split('T')[0];
const yearFrom      = new Date(now.getFullYear(), 0, 1).toISOString().split('T')[0];
const yearTo        = new Date(now.getFullYear(), 11, 31, 23, 59, 59).toISOString().split('T')[0];
const thisMonthFrom = new Date(now.getFullYear(), now.getMonth(), 1).toISOString().split('T')[0];
const thisMonthTo   = new Date(now.getFullYear(), now.getMonth() + 1, 0, 23, 59, 59).toISOString().split('T')[0];
---

<AppLayout title="Dashboard · Flota Vial">
  <div class="page">

    <!-- Header -->
    <header class="header">
      <div>
        <p class="greeting">hola, {user.name?.split(' ')[0] ?? 'usuario'}</p>
        <h1 class="title">Resumen<br />general</h1>
      </div>
      {user.image
        ? <img src={user.image} alt="Perfil" class="avatar-img" loading="lazy" />
        : <div class="avatar-initials">{initials(user.name)}</div>
      }
    </header>

    <!-- Balance card -->
    <div class="balance-card">
      <div class="balance-top">
        <div>
          <p class="balance-label">balance</p>
          <p class={`balance-value ${balance < 0 ? 'neg' : ''}`}>{currency(balance)}</p>
        </div>
        <button id="period-toggle" class="period-btn" aria-expanded="false">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none">
            <rect x="3" y="4" width="18" height="18" rx="3" stroke="rgba(255,255,255,0.8)" stroke-width="1.8"/>
            <path d="M16 2v4M8 2v4M3 10h18" stroke="rgba(255,255,255,0.8)" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
          <span id="period-label" class="period-label">{periodLabel}</span>
          <svg id="period-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" style="transition: transform 0.2s;">
            <path d="M6 9l6 6 6-6" stroke="rgba(255,255,255,0.6)" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
      </div>

      <div class="balance-row">
        <div>
          <p class="balance-row-label">ingresos</p>
          <p class="balance-row-value income" id="total-income">+ {currency(incomeTotal)}</p>
        </div>
        <div class="balance-divider"></div>
        <div>
          <p class="balance-row-label">gastos</p>
          <p class="balance-row-value expense" id="total-expense">− {currency(expenseTotal)}</p>
        </div>
      </div>
    </div>

    <!-- Date picker -->
    <div id="period-modal-overlay" class="period-overlay" aria-hidden="true">
      <div class="period-modal" role="dialog" aria-modal="true">

        <div class="modal-handle"></div>

        <div class="modal-header">
          <div>
            <h2 class="modal-title">Período</h2>
            <p class="modal-subtitle">seleccioná el rango a consultar</p>
          </div>
          <button id="period-modal-close" class="modal-close" aria-label="Cerrar">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none">
              <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
            </svg>
          </button>
        </div>

        <div class="modal-body">
          <div class="picker-chips">
            <button class="chip" data-from={thisMonthFrom} data-to={thisMonthTo}>Este mes</button>
            <button class="chip" data-from={prevMonthFrom} data-to={prevMonthTo}>Mes anterior</button>
            <button class="chip" data-from={yearFrom}      data-to={yearTo}     >Este año</button>
          </div>

          <div class="picker-row">
            <div class="picker-field">
              <label class="picker-label">Desde</label>
              <input id="picker-from" type="date" class="picker-input" value={fromISO} />
            </div>
            <div class="picker-field">
              <label class="picker-label">Hasta</label>
              <input id="picker-to" type="date" class="picker-input" value={toISO} />
            </div>
          </div>

          <button id="picker-apply" class="picker-apply">Aplicar período</button>
        </div>

      </div>
    </div>

    <!-- Acciones rápidas -->
    <div class="quick-actions">
      <button id="btn-new-vehicle" class="action-btn secondary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <path d="M5 16l1-5h12l1 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          <path d="M7 16h10" stroke="currentColor" stroke-width="1.8"/>
          <circle cx="8"  cy="18" r="1.5" fill="currentColor"/>
          <circle cx="16" cy="18" r="1.5" fill="currentColor"/>
        </svg>
        Vehículo
      </button>
      <button id="btn-new-income" class="action-btn primary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <path d="M12 19V5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          <path d="M7 10l5-5 5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Ingreso
      </button>
      <button id="btn-new-expense" class="action-btn danger">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <path d="M12 5v14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          <path d="M17 14l-5 5-5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Gasto
      </button>
    </div>

    <!-- Vehículos -->
    <section class="section">
      <h2 class="section-title">Tus vehículos</h2>
      {userVehicleList.length === 0
        ? <div class="empty-state">No tenés vehículos asociados.</div>
        : userVehicleList.map((v) => (
            <a href="/vehicles" class="vehicle-card">
              <div>
                <span class="badge-plate">{v.plate}</span>
                <p class="vehicle-name">{v.brand} {v.model}</p>
                <p class="vehicle-year">{v.year}</p>
              </div>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                <path d="M9 18l6-6-6-6" stroke="#d1d5db" stroke-width="1.8" stroke-linecap="round"/>
              </svg>
            </a>
          ))
      }
    </section>

    <!-- Movimientos recientes -->
    <section class="section">
      <div class="section-header">
        <h2 class="section-title">Movimientos recientes</h2>
        <span class="section-period">{periodLabel}</span>
      </div>
      {recentTransactions.length === 0
        ? <div class="empty-state">Sin movimientos en este período.</div>
        : recentTransactions.map((tx) => (
            <a href={`/transactions/${tx.type}`} class="tx-card">
              <div class="tx-left">
                <p class="tx-desc">{tx.description}</p>
                <div class="tx-meta">
                  <span class="badge-plate">{tx.plate}</span>
                  <span>{formatDate(tx.date)}</span>
                </div>
              </div>
              <p class={`tx-amount ${tx.type === 'income' ? 'income' : 'expense'}`}>
                {tx.type === 'income' ? '+' : '−'}{currency(tx.amount)}
              </p>
            </a>
          ))
      }
    </section>

  </div>

  <VehicleModal />
  <TransactionModal vehicles={userVehicleList} />
</AppLayout>

<style>
  .page {
    padding: 1.25rem 1.25rem calc(5rem + env(safe-area-inset-bottom));
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    background: var(--color-asphalt);
    min-height: 100dvh;
  }

  /* ── Header ── */
  .header { display: flex; justify-content: space-between; align-items: flex-start; padding: 0.5rem 0; }

  .greeting { font-family: var(--font-mono); font-size: 11px; color: var(--color-navy-mid); letter-spacing: 0.05em; margin-bottom: 4px; }

  .title { font-family: var(--font-display); font-size: 2rem; font-weight: 700; color: var(--color-navy); line-height: 1.05; }

  .avatar-img { width: 42px; height: 42px; border-radius: 50%; object-fit: cover; border: 2.5px solid var(--color-amber-accent); }

  .avatar-initials {
    width: 42px; height: 42px; border-radius: 50%;
    background: var(--color-amber-accent);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-mono); font-size: 13px; font-weight: 500;
    color: var(--color-navy); flex-shrink: 0;
  }

  /* ── Balance card ── */
  .balance-card {
    background: var(--color-navy);
    border-radius: 14px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .balance-top { display: flex; justify-content: space-between; align-items: flex-start; }

  .balance-label { font-family: var(--font-mono); font-size: 9px; color: rgba(255,255,255,0.5); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 4px; }

  .balance-value { font-family: var(--font-display); font-size: 2.25rem; font-weight: 700; color: white; line-height: 1; }
  .balance-value.neg { color: #F7C1C1; }

  .period-btn {
    display: flex; align-items: center; gap: 5px;
    background: rgba(255,255,255,0.12);
    border: none; border-radius: 6px;
    padding: 6px 10px; cursor: pointer;
    transition: background 0.15s;
    flex-shrink: 0;
  }
  .period-btn:hover { background: rgba(255,255,255,0.18); }

  .period-label { font-family: var(--font-mono); font-size: 9px; color: rgba(255,255,255,0.85); letter-spacing: 0.06em; }

  .balance-row { display: flex; align-items: center; gap: 1rem; padding-top: 0.75rem; border-top: 1px solid rgba(255,255,255,0.1); }

  .balance-divider { width: 1px; height: 28px; background: rgba(255,255,255,0.12); }

  .balance-row-label { font-family: var(--font-mono); font-size: 9px; color: rgba(255,255,255,0.45); letter-spacing: 0.06em; margin-bottom: 3px; }

  .balance-row-value { font-family: var(--font-mono); font-size: 13px; font-weight: 500; }
  .balance-row-value.income  { color: #C0DD97; }
  .balance-row-value.expense { color: #F7C1C1; }

  /* ── Date picker ── */
  .date-picker {
    background: white;
    border-radius: 12px;
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    border: 0.5px solid #e5e7eb;
    animation: slideDown 0.2s ease;
  }

  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .picker-chips { display: flex; gap: 6px; flex-wrap: wrap; }

  .chip {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 5px 12px;
    border-radius: 99px;
    border: 0.5px solid #e5e7eb;
    background: #fafafa;
    color: #888780;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.15s;
  }
  .chip:hover      { border-color: var(--color-navy); color: var(--color-navy); }
  .chip.chip-active { background: var(--color-navy); color: white; border-color: var(--color-navy); }

  .picker-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }

  .picker-field { display: flex; flex-direction: column; gap: 4px; }

  .picker-label { font-family: var(--font-mono); font-size: 9px; color: #B4B2A9; letter-spacing: 0.06em; text-transform: uppercase; }

  .picker-input {
    border: 0.5px solid #e5e7eb;
    border-radius: 7px;
    padding: 8px 10px;
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--color-carbon);
    background: #fafafa;
    outline: none;
    transition: border-color 0.15s;
    width: 100%;
  }
  .picker-input:focus { border-color: var(--color-navy-mid); }

  .picker-apply {
    background: var(--color-navy);
    color: white;
    border: none;
    border-radius: 8px;
    padding: 10px;
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }
  .picker-apply:hover { background: var(--color-navy-mid); }

  /* ── Period modal ── */
  .period-overlay {
    position: fixed; inset: 0;
    background: rgba(20, 40, 80, 0.35);
    display: flex; align-items: flex-end;
    z-index: 200;
    opacity: 0; pointer-events: none;
    transition: opacity 0.2s ease;
  }
  .period-overlay.open { opacity: 1; pointer-events: all; }

  .period-modal {
    background: white;
    width: 100%; max-width: 480px;
    margin: 0 auto;
    border-radius: 24px 24px 0 0;
    padding-bottom: calc(1.25rem + env(safe-area-inset-bottom));
    transform: translateY(100%);
    transition: transform 0.25s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .period-overlay.open .period-modal { transform: translateY(0); }

  .modal-handle { width: 32px; height: 3px; background: #B8D0EE; border-radius: 99px; margin: 14px auto 0; }

  .modal-header { display: flex; justify-content: space-between; align-items: flex-start; padding: 16px 18px 0; }

  .modal-title { font-family: var(--font-display); font-size: 22px; font-weight: 700; color: var(--color-navy); line-height: 1; }

  .modal-subtitle { font-family: var(--font-mono); font-size: 9px; color: #B4B2A9; letter-spacing: 0.06em; margin-top: 4px; }

  .modal-close {
    width: 26px; height: 26px; border-radius: 50%;
    background: var(--color-navy-light); color: var(--color-navy);
    border: none; display: flex; align-items: center; justify-content: center;
    cursor: pointer; flex-shrink: 0; margin-top: 2px;
    transition: background 0.15s;
  }
  .modal-close:hover { background: #cce0f5; }

  .modal-body { padding: 16px 18px 0; display: flex; flex-direction: column; gap: 14px; }

  .picker-chips { display: flex; gap: 6px; flex-wrap: wrap; }

  .chip {
    font-family: var(--font-mono); font-size: 10px;
    padding: 6px 14px; border-radius: 99px;
    border: 0.5px solid #e5e7eb; background: #fafafa; color: #888780;
    cursor: pointer; white-space: nowrap; transition: all 0.15s;
  }
  .chip:hover       { border-color: var(--color-navy); color: var(--color-navy); }
  .chip.chip-active { background: var(--color-navy); color: white; border-color: var(--color-navy); }

  .picker-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }

  .picker-field { display: flex; flex-direction: column; gap: 4px; }

  .picker-label { font-family: var(--font-mono); font-size: 9px; color: #B4B2A9; letter-spacing: 0.06em; text-transform: uppercase; }

  .picker-input {
    border: 0.5px solid #e5e7eb; border-radius: 8px;
    padding: 9px 10px; font-family: var(--font-sans);
    font-size: 13px; color: var(--color-carbon);
    background: #fafafa; outline: none; width: 100%;
    transition: border-color 0.15s;
  }
  .picker-input:focus { border-color: var(--color-navy-mid); }

  .picker-apply {
    background: var(--color-navy); color: white; border: none;
    border-radius: 10px; padding: 13px;
    font-family: var(--font-sans); font-size: 13px; font-weight: 600;
    cursor: pointer; transition: background 0.15s;
  }
  .picker-apply:hover { background: var(--color-navy-mid); }

  /* ── Acciones rápidas ── */
  .quick-actions { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }

  .action-btn {
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    padding: 12px 8px; border-radius: 10px;
    font-family: var(--font-mono); font-size: 10px; font-weight: 500; letter-spacing: 0.04em;
    border: none; cursor: pointer;
    transition: opacity 0.15s;
  }
  .action-btn:hover { opacity: 0.85; }
  .action-btn.primary   { background: var(--color-navy); color: white; }
  .action-btn.secondary { background: white; color: var(--color-navy); border: 0.5px solid #e5e7eb; }
  .action-btn.danger    { background: var(--color-expense-light); color: var(--color-expense); }

  /* ── Sections ── */
  .section { display: flex; flex-direction: column; gap: 8px; }

  .section-header { display: flex; justify-content: space-between; align-items: baseline; }

  .section-title { font-family: var(--font-sans); font-size: 13px; font-weight: 600; color: var(--color-navy); }

  .section-period { font-family: var(--font-mono); font-size: 9px; color: #B4B2A9; letter-spacing: 0.04em; }

  /* ── Vehicle card ── */
  .vehicle-card {
    background: white; border-radius: 10px; padding: 12px; border: 0.5px solid #e5e7eb;
    display: flex; justify-content: space-between; align-items: center;
    text-decoration: none; transition: opacity 0.15s;
  }
  .vehicle-card:hover { opacity: 0.85; }

  .vehicle-name { font-family: var(--font-sans); font-size: 14px; font-weight: 600; color: var(--color-carbon); margin-top: 5px; }
  .vehicle-year { font-family: var(--font-mono); font-size: 11px; color: #888780; margin-top: 2px; }

  /* ── Transaction card ── */
  .tx-card {
    background: white; border-radius: 10px; padding: 12px; border: 0.5px solid #e5e7eb;
    display: flex; justify-content: space-between; align-items: center;
    text-decoration: none; transition: opacity 0.15s;
  }
  .tx-card:hover { opacity: 0.85; }

  .tx-left { flex: 1; min-width: 0; }
  .tx-desc { font-family: var(--font-sans); font-size: 13px; font-weight: 600; color: var(--color-carbon); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .tx-meta { display: flex; align-items: center; gap: 6px; margin-top: 4px; font-family: var(--font-mono); font-size: 10px; color: #888780; }

  .tx-amount { font-family: var(--font-mono); font-size: 13px; font-weight: 500; white-space: nowrap; margin-left: 12px; }
  .tx-amount.income  { color: var(--color-income); }
  .tx-amount.expense { color: var(--color-expense); }

  /* ── Empty state ── */
  .empty-state {
    background: white; border: 0.5px dashed #d1d5db; border-radius: 10px;
    padding: 1.25rem; text-align: center;
    font-family: var(--font-mono); font-size: 11px; color: #888780; letter-spacing: 0.04em;
  }
</style>

<script define:vars={{ thisMonthFrom, thisMonthTo, prevMonthFrom, prevMonthTo, yearFrom, yearTo }}>
  // ── Period modal ─────────────────────────────────────────────────────────
  const periodOverlay = document.getElementById('period-modal-overlay');
  const periodClose   = document.getElementById('period-modal-close');
  const periodToggle  = document.getElementById('period-toggle');
  const pickerFrom    = document.getElementById('picker-from');
  const pickerTo      = document.getElementById('picker-to');

  function openPeriodModal() {
    periodOverlay.classList.add('open');
    periodOverlay.setAttribute('aria-hidden', 'false');
  }

  function closePeriodModal() {
    periodOverlay.classList.remove('open');
    periodOverlay.setAttribute('aria-hidden', 'true');
  }

  periodToggle?.addEventListener('click', openPeriodModal);
  periodClose?.addEventListener('click', closePeriodModal);
  periodOverlay?.addEventListener('click', (e) => { if (e.target === periodOverlay) closePeriodModal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closePeriodModal(); });

  // ── Chips ────────────────────────────────────────────────────────────────
  document.querySelectorAll('.chip').forEach((chip) => {
    chip.addEventListener('click', () => {
      document.querySelectorAll('.chip').forEach((c) => c.classList.remove('chip-active'));
      chip.classList.add('chip-active');
      pickerFrom.value = chip.dataset.from;
      pickerTo.value   = chip.dataset.to;
    });
  });

  // Marcar chip activo al cargar
  document.querySelectorAll('.chip').forEach((chip) => {
    if (chip.dataset.from === pickerFrom.value && chip.dataset.to === pickerTo.value) {
      chip.classList.add('chip-active');
    }
  });

  // Si el usuario edita las fechas manualmente, deseleccionar chips
  [pickerFrom, pickerTo].forEach((input) => {
    input?.addEventListener('change', () => {
      document.querySelectorAll('.chip').forEach((c) => c.classList.remove('chip-active'));
    });
  });

  // ── Apply ────────────────────────────────────────────────────────────────
  document.getElementById('picker-apply')?.addEventListener('click', () => {
    const from = pickerFrom.value;
    const to   = pickerTo.value;
    if (!from || !to) return;
    const url = new URL(window.location.href);
    url.searchParams.set('from', from);
    url.searchParams.set('to',   to);
    window.location.href = url.toString();
  });

  // ── Action buttons ───────────────────────────────────────────────────────
  document.getElementById('btn-new-vehicle')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('open-vehicle-modal'));
  });

  document.getElementById('btn-new-income')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('open-tx-modal', { detail: { type: 'income' } }));
  });

  document.getElementById('btn-new-expense')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('open-tx-modal', { detail: { type: 'expense' } }));
  });
</script>