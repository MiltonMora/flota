---
import Nav from '@/components/Nav.astro';

interface Props {
  title?: string;
}

const { title = 'Flota Vial' } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <style is:global>
      @import '@/styles/global.css';
    </style>
  </head>
  <body>
    <main class="app-container">
      <slot />
    </main>

    <Nav />
  </body>
</html>

<style>
  .app-container {
    min-height: 100dvh;
    max-width: 480px;
    margin: 0 auto;
    padding-bottom: 90px; /* espacio para nav */
    background-color: var(--color-asphalt);
  }
</style>