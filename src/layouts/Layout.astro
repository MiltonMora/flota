---
interface Props { title?: string; }
const { title = 'Flota Vial' } = Astro.props;
---
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style is:global>
      @import '@/styles/global.css';
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>