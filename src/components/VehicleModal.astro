---
// Sin props, se controla desde el exterior con open/close
---

<div id="vehicle-modal-overlay" class="overlay" aria-hidden="true">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modal-title">

    <div class="modal-handle"></div>

    <div class="modal-header">
      <h2 id="modal-title" class="modal-title">Nuevo vehículo</h2>
      <button id="modal-close" class="modal-close" aria-label="Cerrar">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
          <path d="M18 6L6 18M6 6l12 12" stroke="#888780" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <div id="modal-error" class="modal-error" style="display:none;"></div>

    <div class="modal-body">
      <div class="field">
        <label for="v-plate">Matrícula</label>
        <input id="v-plate" name="plate" type="text" maxlength="12"
          class="input plate-input" placeholder="1234 ABC" autocomplete="off" required />
      </div>

      <div class="grid-2">
        <div class="field">
          <label for="v-brand">Marca</label>
          <input id="v-brand" name="brand" type="text"
            class="input" placeholder="Toyota" required />
        </div>
        <div class="field">
          <label for="v-model">Modelo</label>
          <input id="v-model" name="model" type="text"
            class="input" placeholder="Corolla" required />
        </div>
      </div>

      <div class="field">
        <label for="v-year">Año</label>
        <input id="v-year" name="year" type="number"
          class="input" placeholder="2024"
          min="1900" max={new Date().getFullYear() + 1} required />
      </div>

      <div class="field">
        <label for="v-description">Notas <span class="optional">opcional</span></label>
        <textarea id="v-description" name="description"
          class="input textarea" rows="2"
          placeholder="Color, uso, observaciones..."></textarea>
      </div>
    </div>

    <div class="modal-actions">
      <button id="modal-cancel" class="btn-cancel">Cancelar</button>
      <button id="modal-submit" class="btn-save">
        <span id="submit-text">Guardar</span>
        <span id="submit-loader" style="display:none;">
          <svg class="spinner" width="14" height="14" viewBox="0 0 16 16" fill="none">
            <circle cx="8" cy="8" r="6" stroke="rgba(255,255,255,0.3)" stroke-width="2"/>
            <path d="M8 2a6 6 0 0 1 6 6" stroke="white" stroke-width="2" stroke-linecap="round"/>
          </svg>
          Guardando...
        </span>
      </button>
    </div>

  </div>
</div>

<style>
  .overlay {
    position: fixed;
    inset: 0;
    background: rgba(28, 63, 110, 0.45);
    display: flex;
    align-items: flex-end;
    z-index: 200;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }

  .overlay.open {
    opacity: 1;
    pointer-events: all;
  }

  .modal {
    background: white;
    width: 100%;
    max-width: 480px;
    margin: 0 auto;
    border-radius: 20px 20px 0 0;
    padding-bottom: calc(1rem + env(safe-area-inset-bottom));
    transform: translateY(100%);
    transition: transform 0.25s cubic-bezier(0.32, 0.72, 0, 1);
  }

  .overlay.open .modal {
    transform: translateY(0);
  }

  .modal-handle {
    width: 36px;
    height: 4px;
    background: #e5e7eb;
    border-radius: 99px;
    margin: 12px auto 0;
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 18px 12px;
    border-bottom: 0.5px solid #f0f0f0;
  }

  .modal-title {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    color: var(--color-navy);
  }

  .modal-close {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: #F5F4F0;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.15s;
  }
  .modal-close:hover { background: #e5e7eb; }

  .modal-error {
    margin: 10px 18px 0;
    background: var(--color-expense-light);
    color: var(--color-expense);
    font-family: var(--font-sans);
    font-size: 12px;
    padding: 10px 12px;
    border-radius: 8px;
    line-height: 1.5;
  }

  .modal-body {
    padding: 14px 18px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  label {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--color-navy-mid);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .optional {
    color: #B4B2A9;
    font-size: 9px;
    text-transform: none;
    letter-spacing: 0;
  }

  .input {
    border: 0.5px solid #e5e7eb;
    border-radius: 8px;
    padding: 10px 12px;
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--color-carbon);
    background: #fafafa;
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
    width: 100%;
  }
  .input:focus {
    border-color: var(--color-navy-mid);
    box-shadow: 0 0 0 3px var(--color-navy-light);
    background: white;
  }

  .plate-input {
    font-family: var(--font-mono);
    font-size: 16px;
    letter-spacing: 0.12em;
    text-align: center;
    font-weight: 500;
    text-transform: uppercase;
  }

  .textarea {
    resize: none;
    min-height: 70px;
  }

  .grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }

  .modal-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    padding: 4px 18px 0;
  }

  .btn-cancel {
    padding: 12px;
    border-radius: 9px;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 600;
    background: #F5F4F0;
    color: #5F5E5A;
    border: none;
    cursor: pointer;
    transition: background 0.15s;
  }
  .btn-cancel:hover { background: #e5e7eb; }

  .btn-save {
    padding: 12px;
    border-radius: 9px;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 600;
    background: var(--color-navy);
    color: white;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    transition: background 0.15s;
  }
  .btn-save:hover   { background: var(--color-navy-mid); }
  .btn-save:disabled { opacity: 0.7; cursor: not-allowed; }

  .spinner {
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
</style>

<script>
  const overlay  = document.getElementById('vehicle-modal-overlay')!;
  const btnClose  = document.getElementById('modal-close')!;
  const btnCancel = document.getElementById('modal-cancel')!;
  const btnSubmit = document.getElementById('modal-submit') as HTMLButtonElement;
  const errorBox  = document.getElementById('modal-error')!;
  const submitText   = document.getElementById('submit-text')!;
  const submitLoader = document.getElementById('submit-loader')!;

  const inputs = {
    plate:       document.getElementById('v-plate')       as HTMLInputElement,
    brand:       document.getElementById('v-brand')       as HTMLInputElement,
    model:       document.getElementById('v-model')       as HTMLInputElement,
    year:        document.getElementById('v-year')        as HTMLInputElement,
    description: document.getElementById('v-description') as HTMLTextAreaElement,
  };

  // Escuchar el evento global para abrir
  document.addEventListener('open-vehicle-modal', () => openModal());

  function openModal() {
    overlay.classList.add('open');
    overlay.setAttribute('aria-hidden', 'false');
    inputs.plate.focus();
  }

  function closeModal() {
    overlay.classList.remove('open');
    overlay.setAttribute('aria-hidden', 'true');
    resetForm();
  }

  function resetForm() {
    Object.values(inputs).forEach((el) => (el.value = ''));
    showError('');
  }

  function showError(msg: string) {
    errorBox.textContent = msg;
    errorBox.style.display = msg ? 'block' : 'none';
  }

  function setLoading(on: boolean) {
    btnSubmit.disabled  = on;
    submitText.style.display   = on ? 'none'  : 'inline';
    submitLoader.style.display = on ? 'flex'  : 'none';
  }

  // Cerrar
  btnClose.addEventListener('click', closeModal);
  btnCancel.addEventListener('click', closeModal);
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) closeModal();
  });

  // Cerrar con Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });

  // Submit
  btnSubmit.addEventListener('click', async () => {
    showError('');

    const data = {
      plate:       inputs.plate.value.trim(),
      brand:       inputs.brand.value.trim(),
      model:       inputs.model.value.trim(),
      year:        inputs.year.value,
      description: inputs.description.value.trim(),
    };

    if (!data.plate || !data.brand || !data.model || !data.year) {
      showError('Completá los campos obligatorios.');
      return;
    }

    setLoading(true);

    try {
      const res = await fetch('/api/vehicles/create', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(data),
      });

      const json = await res.json();

      if (!res.ok) {
        showError(json.error ?? 'Error al guardar.');
        return;
      }

      closeModal();
      window.location.reload();
    } catch {
      showError('Error de conexión. Intentá de nuevo.');
    } finally {
      setLoading(false);
    }
  });
</script>